{
	"name": "webpull",
	"version": "0.1.3",
	"description": "Pull any public docs site into local markdown files",
	"module": "src/index.ts",
	"type": "module",
	"bin": {
		"webpull": "bin/webpull"
	},
	"files": [
		"bin",
		"scripts/daemon.ts",
		"src",
		"!src/.tmp-*",
		"ui/index.html",
		"ui/src",
		"ui/dist",
		"!ui/dist/*.map"
	],
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@types/bun": "latest",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@types/react-syntax-highlighter": "^15.5.13",
		"wrangler": "^4.100.0"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"defuddle": "^0.18.1",
		"effect": "^3.21.2",
		"linkedom": "^0.18.12",
		"playwright": "^1.59.1",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-markdown": "^10.1.0",
		"react-router-dom": "^7.17.0",
		"react-syntax-highlighter": "^16.1.1",
		"remark-gfm": "^4.0.1",
		"zod": "^4.4.3"
	},
	"scripts": {
		"build:ui": "bun build ui/src/main.tsx --outdir ui/dist --target browser",
		"prepack": "bun run build:ui",
		"start": "bun run src/index.ts",
		"server:start": "bun run scripts/daemon.ts",
		"server:stop": "pkill -f 'bun run src/index.ts --server' 2>/dev/null; echo 'Server stopped'",
		"server:status": "curl --max-time 5 -s -o /dev/null -w '%{http_code}' http://localhost:${WEBPULL_PORT:-3456}/ 2>/dev/null || echo 'down'",
		"test:api": "bun run test/api.ts",
		"test:cli": "bun run test/cli.ts",
		"test:cloudflare-ui": "bun run test/cloudflare-ui.ts",
		"test:cloudflare-mcp": "bun run test/cloudflare-mcp.ts",
		"test:cloudflare-sources": "bun run test/cloudflare-sources.ts",
		"test:db": "bun run test/db.ts",
		"test:e2e": "bun run test/e2e.ts",
		"test:mcp": "bun run test/mcp.ts",
		"test:pack": "bun run test/pack.ts",
		"test:packed-runtime": "bun run test/packed-runtime.ts",
		"test:smoke": "bun run test/smoke.ts",
		"test:smoke:existing": "bun run test:e2e && bun run test:mcp",
		"dev": "WEBPULL_WATCH=1 bun run start",
		"cloudflare:build": "bun run scripts/build-cloudflare-assets.ts",
		"cloudflare:schema": "wrangler d1 execute webpull --remote --file ./cloudflare/schema.sql",
		"cloudflare:types": "wrangler types cloudflare/worker-configuration.d.ts",
		"cloudflare:dev": "bun run cloudflare:build && wrangler dev",
		"cloudflare:deploy": "bun run cloudflare:build && wrangler deploy"
	}
}
